{
  "manifest_version": 3,
  "name": "Unshittified YouTube",
  "description": "Toggleable YouTube UI tweaks for Chrome and Firefox.",
  "version": "0.1.0",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "src/scripts/settings-schema.js",
        "src/scripts/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "src/pages/config-tools.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Unshittified YouTube",
    "default_popup": "src/pages/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-action-16.png",
      "32": "assets/icons/icon-action-32.png",
      "48": "assets/icons/icon-action-48.png"
    }
  }
}