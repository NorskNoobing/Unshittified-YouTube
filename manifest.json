{
  "manifest_version": 3,
  "name": "Unshittified YouTube",
  "description": "Toggleable YouTube UI tweaks for Chrome and Firefox.",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "src/scripts/settings-schema.js",
        "src/scripts/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "src/pages/config-tools.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Unshittified YouTube",
    "default_popup": "src/pages/popup.html"
  }
}