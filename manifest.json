{
  "manifest_version": 3,
  "name": "YouTube Tweaks",
  "description": "Toggleable YouTube UI tweaks for Chrome and Firefox.",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "YouTube Tweaks",
    "default_popup": "popup.html"
  }
}
